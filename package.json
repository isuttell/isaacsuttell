{
  "name": "isaacsuttell",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@isaacsuttell/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "convex": "^1.31.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "knip": "^5",
    "next": "16.1.1",
    "prettier": "^3.7.4",
    "turbo": "^2",
    "typescript-eslint": "^8.51.0"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "dependencies": {
    "cm6-theme-basic-dark": "^0.2.0"
  }
}
